# Server
PORT=3000

# Base URL for QR code links (e.g. https://yourschool.edu or https://sentinel-ytct.onrender.com)
# Set this on Render / production so QR codes point to the deployed app
DOMAIN=http://localhost:3000

# Admin auth
# Change these in your real .env (do not commit secrets).
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-long-random-string

# Email — loan + return receipts (all three SMTP_* lines below are required to send mail)
# Google Workspace: use smtp.gmail.com, SMTP_USER = full Workspace address, SMTP_PASS = App Password (spaces optional).
# Do not prefix lines with "export ". Restart the server after editing this file.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.edu
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Sentinel <you@yourdomain.edu>

# Optional aliases (same as SMTP_USER / SMTP_PASS if you prefer)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
