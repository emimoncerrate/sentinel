# Server — Render sets PORT automatically; locally defaults to 3000.
# On Render you can pin Node via NODE_VERSION (see render.yaml); local dev can use `.node-version`.
PORT=3000

# Public HTTPS URL (no trailing slash). Required on Render so QR codes and labels point to production.
# Example: https://sentinel-xxxx.onrender.com
DOMAIN=http://localhost:3000

# SQLite directory — default ./data (creates data/sentinel.db). On Render, database is lost on redeploy
# unless you attach a persistent disk and set DATA_DIR to the mount path (e.g. /var/data).
# DATA_DIR=./data

# Behind Reverse Proxy — Render / nginx. Enables secure session cookies with NODE_ENV=production.
# TRUST_PROXY=1

# Admin auth — never commit real values.
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-long-random-string-use-openssl-rand-hex-32

# Email — loan + return receipts (SMTP_HOST, SMTP_USER, SMTP_PASS required to send)
# Google Workspace: smtp.gmail.com; SMTP_USER = full mailbox; SMTP_PASS = App Password (spaces OK).
# Do not prefix lines with "export ". Restart after edits.

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@yourdomain.edu
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Sentinel <you@yourdomain.edu>

# Optional aliases (same as SMTP_USER / SMTP_PASS if you prefer)
# GMAIL_USER=
# GMAIL_APP_PASSWORD=
